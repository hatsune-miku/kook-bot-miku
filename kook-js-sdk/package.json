{
  "name": "@kookapp/js-sdk",
  "version": "0.1.0",
  "description": "Official KOOK Bot JavaScript/TypeScript SDK",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./plugins/*": {
      "types": "./dist/plugins/*/index.d.ts",
      "require": "./dist/plugins/*/index.js",
      "import": "./dist/plugins/*/index.js",
      "default": "./dist/plugins/*/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "docs": "typedoc"
  },
  "dependencies": {
    "ws": "^8.18.0",
    "pako": "^2.1.0",
    "radash": "^12.1.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "@types/ws": "^8.5.0",
    "@types/pako": "^2.0.0",
    "eslint": "^9.0.0",
    "@eslint/js": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "prettier": "^3.4.0",
    "@trivago/prettier-plugin-sort-imports": "^5.2.0",
    "typedoc": "^0.27.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nickyc975/kook-js-sdk.git"
  },
  "keywords": [
    "kook",
    "bot",
    "sdk",
    "websocket",
    "discord-like"
  ]
}
